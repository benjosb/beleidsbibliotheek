# Kopieer naar .env (niet committen). Vul aan na registratie bij KOOP / datasetkeuze.

# Optioneel: SRU endpoint officielebekendmakingen (na goedkeuring KOOP)
# SRU_BASE_URL=
# SRU_COLLECTION=

# Optioneel: basis-URL voor lokale regelgeving API of dataset-endpoint (zie README)
# LOV_API_BASE_URL=

# Optioneel: e-mail SMTP voor rapport (later)
# SMTP_HOST=
# SMTP_USER=
# SMTP_PASS=
# RAPPORT_NAAR=
